# Database
DATABASE_URL=postgresql+asyncpg://pymander:pymander@localhost:5432/pymander

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_URL=redis://localhost:6379/0

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pymander

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# MinIO / S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Reddit (register at reddit.com/prefs/apps — "script" type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pymander/0.1.0 (by /u/your_username)

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Anthropic (for narrative validation)
ANTHROPIC_API_KEY=

# App
LOG_LEVEL=DEBUG
