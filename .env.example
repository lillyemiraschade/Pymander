# Database (Supabase pooler or local)
DATABASE_URL=postgresql+asyncpg://pymander:pymander@localhost:5432/pymander

# Kafka (Upstash or local)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=SCRAM-SHA-256

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379/0

# Neo4j (Aura or local)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pymander

# Reddit (register at reddit.com/prefs/apps — "script" type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pymander/0.1.0 (by /u/your_username)

# Twitter/X (developer.twitter.com)
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Telegram (my.telegram.org)
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=

# YouTube (console.cloud.google.com)
YOUTUBE_API_KEY=
YOUTUBE_DAILY_QUOTA=10000

# Bluesky
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# Google Trends
GOOGLE_TRENDS_REGIONS=US,GB,DE

# Qdrant (Cloud or local)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Anthropic (for narrative validation + briefings)
ANTHROPIC_API_KEY=
ANTHROPIC_BRIEFING_MODEL=claude-sonnet-4-5-20250929

# API Authentication
API_SECRET_KEY=change-me-in-production
API_RATE_LIMIT_PER_MINUTE=100

# App
LOG_LEVEL=DEBUG
